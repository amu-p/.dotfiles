syntax on
set nocompatible

set clipboard=unnamed,unnamedplus

set nobackup
set nowritebackup
set noswapfile

set fenc=utf-8

set number                
set expandtab

set tabstop=2
set shiftwidth=2
set smartindent

set backspace=indent,eol,start
set cursorline
set hlsearch

inoremap <silent> jj <ESC>
